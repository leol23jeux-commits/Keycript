<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Keycrypt</title>
<meta name="description" content="Keycrypt code et décode tes mots en utilisant les symboles de ton clavier AZERTY. Simple, rapide, gratuit — colle un mot, obtiens son code en un clic.">
<link rel="icon" type="image/svg+xml" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 512 512'%3E%3Crect width='512' height='512' rx='96' fill='%23141418'/%3E%3Crect x='72' y='152' width='368' height='208' rx='40' fill='%23232328' stroke='%233a3a42' stroke-width='4'/%3E%3Ctext x='150' y='298' font-family='monospace' font-size='130' font-weight='700' fill='%23f2f2f4' text-anchor='middle'%3EA%3C/text%3E%3Cpath d='M218 256 L278 256 M258 234 L280 256 L258 278' stroke='%234c8dff' stroke-width='10' stroke-linecap='round' stroke-linejoin='round' fill='none'/%3E%3Ctext x='352' y='298' font-family='monospace' font-size='130' font-weight='800' fill='%234c8dff' text-anchor='middle'%3E1%3C/text%3E%3C/svg%3E">
<style>
  @import url('https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;700;800&family=Fraunces:opsz,wght@9..144,500;9..144,700&display=swap');

  :root{
    --bg:#141418;
    --key:#232328;
    --key-top:#2c2c32;
    --key-border:#38383f;
    --accent:#4c8dff;
    --accent-soft:#4c8dff33;
    --text:#f2f2f4;
    --muted:#8a8a93;
  }
  *{box-sizing:border-box;}
  body{
    margin:0;
    min-height:100vh;
    background:
      radial-gradient(circle at 15% 0%, #1c1c24 0%, transparent 55%),
      radial-gradient(circle at 85% 100%, #1a1e2b 0%, transparent 55%),
      var(--bg);
    color:var(--text);
    font-family:'JetBrains Mono', monospace;
    display:flex;
    flex-direction:column;
    align-items:center;
    padding:32px 18px 60px;
  }

  header{
    text-align:center;
    margin-bottom:28px;
  }
  .eyebrow{
    font-size:11px;
    letter-spacing:0.28em;
    text-transform:uppercase;
    color:var(--accent);
    margin-bottom:10px;
    font-weight:700;
  }
  h1{
    font-family:'Fraunces', serif;
    font-size:38px;
    font-weight:700;
    margin:0 0 8px;
    letter-spacing:-0.01em;
  }
  header p{
    color:var(--muted);
    font-size:13.5px;
    margin:0;
    max-width:360px;
  }

  .panel{
    width:100%;
    max-width:520px;
    background:linear-gradient(180deg, #1b1b21, #17171c);
    border:1px solid #2a2a31;
    border-radius:20px;
    padding:24px;
    box-shadow:0 20px 50px -20px rgba(0,0,0,0.6);
  }

  label{
    display:block;
    font-size:11px;
    letter-spacing:0.12em;
    text-transform:uppercase;
    color:var(--muted);
    margin-bottom:8px;
  }

  textarea{
    width:100%;
    min-height:90px;
    resize:vertical;
    background:#0f0f13;
    border:1px solid #2e2e36;
    border-radius:12px;
    padding:14px;
    color:var(--text);
    font-family:'JetBrains Mono', monospace;
    font-size:16px;
    line-height:1.5;
    outline:none;
    transition:border-color .15s ease;
  }
  textarea:focus{
    border-color:var(--accent);
    box-shadow:0 0 0 3px var(--accent-soft);
  }

  .buttons{
    display:flex;
    gap:10px;
    margin:18px 0;
  }
  button{
    flex:1;
    font-family:'JetBrains Mono', monospace;
    font-size:13px;
    font-weight:700;
    letter-spacing:0.04em;
    padding:13px 10px;
    border-radius:12px;
    border:1px solid var(--key-border);
    background:linear-gradient(180deg, var(--key-top), var(--key));
    color:var(--text);
    cursor:pointer;
    transition:transform .08s ease, background .15s ease, border-color .15s ease;
  }
  button:active{ transform:translateY(2px); }
  button.primary{
    background:linear-gradient(180deg, #5a97ff, var(--accent));
    border-color:#5a97ff;
    color:#0d1420;
  }
  button.ghost{
    background:transparent;
    color:var(--muted);
  }

  .output-wrap{
    position:relative;
  }
  #output{
    background:#0f0f13;
  }
  #output[data-empty="true"]::before{
    content: attr(data-placeholder);
    color:var(--muted);
  }
  .output-label-row{
    display:flex;
    align-items:center;
    justify-content:space-between;
  }
  #copyBtn{
    display:flex;
    align-items:center;
    gap:6px;
    background:none;
    border:1px solid var(--key-border);
    color:var(--muted);
    font-family:'JetBrains Mono', monospace;
    font-size:11px;
    letter-spacing:0.06em;
    text-transform:uppercase;
    padding:5px 10px;
    border-radius:8px;
    cursor:pointer;
    flex:none;
    transition:border-color .15s ease, color .15s ease;
  }
  #copyBtn:hover{
    border-color:var(--accent);
    color:var(--accent);
  }
  #copyBtn.copied{
    border-color:var(--accent);
    color:var(--accent);
  }
  #copyBtn svg{ width:13px; height:13px; }

  .keystrip{
    display:flex;
    flex-wrap:wrap;
    gap:6px;
    margin-top:20px;
    min-height:38px;
  }
  .keycap{
    display:flex;
    align-items:center;
    justify-content:center;
    min-width:34px;
    height:34px;
    padding:0 4px;
    border-radius:8px;
    background:linear-gradient(180deg, var(--key-top), var(--key));
    border:1px solid var(--key-border);
    font-size:14px;
    font-weight:700;
    color:var(--accent);
    animation:pop .2s ease;
  }
  @keyframes pop{
    from{ transform:scale(0.7); opacity:0; }
    to{ transform:scale(1); opacity:1; }
  }

  footer{
    margin-top:26px;
    text-align:center;
  }
  .toggle-table{
    background:none;
    border:none;
    color:var(--muted);
    font-family:'JetBrains Mono', monospace;
    font-size:12px;
    text-decoration:underline;
    cursor:pointer;
    padding:8px;
  }

  table{
    border-collapse:collapse;
    margin:14px auto 0;
    font-size:13px;
  }
  td, th{
    border:1px solid #2a2a31;
    padding:6px 10px;
    text-align:center;
  }
  th{ color:var(--muted); font-weight:500; }
  td.letter{ color:var(--text); font-weight:700; }
  td.code{ color:var(--accent); }

  #tableWrap{ display:none; }

  @media (prefers-reduced-motion: reduce){
    .keycap{ animation:none; }
  }
</style>
</head>
<body>

<header>
  <div class="eyebrow">AZERTY · Chiffrement</div>
  <h1>Keycrypt</h1>
  <p>Un clavier, un code secret. Transforme tes mots en symboles AZERTY.</p>
</header>

<div class="panel">
  <label for="input">Mot ou phrase</label>
  <textarea id="input" placeholder="Écris ici..." autofocus></textarea>

  <div class="buttons">
    <button class="primary" id="encodeBtn">Coder →</button>
    <button id="decodeBtn">← Décoder</button>
    <button class="ghost" id="clearBtn">Effacer</button>
  </div>

  <div class="output-wrap">
    <div class="output-label-row">
      <label for="output">Résultat</label>
      <button id="copyBtn" type="button">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>
        <span id="copyLabel">Copier</span>
      </button>
    </div>
    <textarea id="output" readonly data-placeholder="Le résultat s'affiche ici..." data-empty="true"></textarea>
  </div>

  <div class="keystrip" id="keystrip"></div>
</div>

<footer>
  <button class="toggle-table" id="toggleTable">Voir la table de correspondance</button>
  <div id="tableWrap"></div>
</footer>

<script>
  const MAP = {
    'a':'1', 'b':'2', 'c':'3', 'd':'4', 'e':'5', 'f':'6', 'g':'7', 'h':'8', 'i':'9',
    'j':'0', 'k':'&', 'l':'-', 'm':'/', 'n':':', 'o':';', 'p':'(', 'q':')', 'r':'€',
    's':'@', 't':'"', 'u':'.', 'v':',', 'w':'?', 'x':"'", 'y':'!', 'z':'#'
  };
  const REVERSE = Object.fromEntries(Object.entries(MAP).map(([k,v]) => [v,k]));

  const input = document.getElementById('input');
  const output = document.getElementById('output');
  const keystrip = document.getElementById('keystrip');

  function setOutput(text){
    output.value = text;
    output.setAttribute('data-empty', text.length === 0 ? 'true' : 'false');
  }

  function renderKeystrip(pairs){
    keystrip.innerHTML = '';
    pairs.forEach(([from, to]) => {
      const cap = document.createElement('div');
      cap.className = 'keycap';
      cap.textContent = to;
      keystrip.appendChild(cap);
    });
  }

  function encode(){
    const text = input.value;
    const pairs = [];
    let result = '';
    for(const ch of text){
      const lower = ch.toLowerCase();
      if(MAP[lower]){
        result += MAP[lower];
        pairs.push([ch, MAP[lower]]);
      } else {
        result += ch;
      }
    }
    setOutput(result);
    renderKeystrip(pairs);
  }

  function decode(){
    const text = input.value;
    const pairs = [];
    let result = '';
    for(const ch of text){
      if(REVERSE[ch]){
        result += REVERSE[ch];
        pairs.push([ch, REVERSE[ch]]);
      } else {
        result += ch;
      }
    }
    setOutput(result);
    renderKeystrip(pairs);
  }

  const copyBtn = document.getElementById('copyBtn');
  const copyLabel = document.getElementById('copyLabel');

  copyBtn.addEventListener('click', async () => {
    if(!output.value) return;
    try{
      await navigator.clipboard.writeText(output.value);
    } catch(err){
      output.removeAttribute('readonly');
      output.select();
      document.execCommand('copy');
      output.setAttribute('readonly', true);
    }
    copyBtn.classList.add('copied');
    copyLabel.textContent = 'Copié !';
    setTimeout(() => {
      copyBtn.classList.remove('copied');
      copyLabel.textContent = 'Copier';
    }, 1500);
  });

  document.getElementById('encodeBtn').addEventListener('click', encode);
  document.getElementById('decodeBtn').addEventListener('click', decode);
  document.getElementById('clearBtn').addEventListener('click', () => {
    input.value = '';
    setOutput('');
    keystrip.innerHTML = '';
    input.focus();
  });

  input.addEventListener('keydown', (e) => {
    if(e.key === 'Enter'){
      e.preventDefault();
      encode();
    }
  });

  // Table de correspondance
  const toggleBtn = document.getElementById('toggleTable');
  const tableWrap = document.getElementById('tableWrap');
  let tableBuilt = false;

  toggleBtn.addEventListener('click', () => {
    const isHidden = tableWrap.style.display === 'none' || tableWrap.style.display === '';
    if(!tableBuilt){
      buildTable();
      tableBuilt = true;
    }
    tableWrap.style.display = isHidden ? 'block' : 'none';
    toggleBtn.textContent = isHidden ? 'Masquer la table' : 'Voir la table de correspondance';
  });

  function buildTable(){
    const entries = Object.entries(MAP);
    const cols = 5;
    const rows = Math.ceil(entries.length / cols);
    const table = document.createElement('table');

    for(let r = 0; r < rows; r++){
      const trLetter = document.createElement('tr');
      const trCode = document.createElement('tr');
      for(let c = 0; c < cols; c++){
        const idx = r * cols + c;
        if(idx < entries.length){
          const [letter, code] = entries[idx];
          const tdL = document.createElement('td');
          tdL.className = 'letter';
          tdL.textContent = letter.toUpperCase();
          const tdC = document.createElement('td');
          tdC.className = 'code';
          tdC.textContent = code;
          trLetter.appendChild(tdL);
          trCode.appendChild(tdC);
        }
      }
      table.appendChild(trLetter);
      table.appendChild(trCode);
    }
    tableWrap.innerHTML = '';
    tableWrap.appendChild(table);
  }
</script>

</body>
</html>
